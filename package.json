{
  "name": "trailcast",
  "version": "1.0.0",
  "description": "旅の記録やオフ会の記録を、スレッド形式でリアルタイムに残して共有するアプリ。",
  "private": true,
  "scripts": {
    "prepare:client-metadata": "node scripts/prepare-client-metadata.mjs",
    "predev": "npm run prepare:client-metadata",
    "dev": "next dev --turbopack -H 0.0.0.0",
    "prebuild": "npm run prepare:client-metadata",
    "build": "next build",
    "preview": "npx wrangler pages dev out",
    "deploy": "npm run build && npx wrangler pages deploy out",
    "og:test": "tsx scripts/og-test.ts",
    "lint": "next lint",
    "tauri": "tauri"
  },
  "dependencies": {
    "@atproto/api": "^0.19.6",
    "@atproto/oauth-client-browser": "^0.3.41",
    "@tauri-apps/api": "^2.10.1",
    "exifr": "^7.1.3",
    "next": "^16.2.2",
    "react": "^19.2.4",
    "react-dom": "^19.2.4",
    "zustand": "^5.0.12"
  },
  "devDependencies": {
    "@next/eslint-plugin-next": "^16.2.2",
    "@tailwindcss/postcss": "^4.2.2",
    "@tauri-apps/cli": "^2.10.1",
    "@types/node": "22.19.17",
    "@types/react": "19.2.14",
    "@types/react-dom": "^19.1.6",
    "eslint": "^9.39.4",
    "eslint-config-next": "^16.2.2",
    "postcss": "^8.5.9",
    "tailwindcss": "^4.2.2",
    "tsx": "^4.21.0",
    "typescript": "5.9.3",
    "typescript-eslint": "^8.58.1"
  }
}
