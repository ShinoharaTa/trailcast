{
  "lexicon": 1,
  "id": "net.shino3.trailcast.thread",
  "defs": {
    "main": {
      "type": "record",
      "description": "A trail / event thread",
      "key": "tid",
      "record": {
        "type": "object",
        "required": ["title", "visibility", "createdAt"],
        "properties": {
          "title": {
            "type": "string",
            "maxLength": 100,
            "description": "Thread title"
          },
          "description": {
            "type": "string",
            "maxLength": 500,
            "description": "Thread description"
          },
          "visibility": {
            "type": "string",
            "knownValues": ["private", "public"],
            "description": "Visibility setting"
          },
          "coverImage": {
            "type": "blob",
            "accept": ["image/jpeg", "image/png", "image/webp"],
            "maxSize": 1000000,
            "description": "Cover image"
          },
          "ogImage": {
            "type": "blob",
            "accept": ["image/jpeg", "image/png", "image/webp"],
            "maxSize": 500000,
            "description": "Auto-generated Open Graph image (1200x630). Stored separately from coverImage so the cover can be human-curated while ogImage is regenerated from the latest thread state."
          },
          "createdAt": {
            "type": "string",
            "format": "datetime",
            "description": "Creation timestamp"
          },
          "sortOrder": {
            "type": "string",
            "knownValues": ["asc", "desc"],
            "description": "Display order of checkpoints by checkpointAt. 'asc' (default) shows oldest first, 'desc' shows newest first."
          }
        }
      }
    }
  }
}
