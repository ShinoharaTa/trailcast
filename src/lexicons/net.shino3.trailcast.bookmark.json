{
  "lexicon": 1,
  "id": "net.shino3.trailcast.bookmark",
  "defs": {
    "main": {
      "type": "record",
      "description": "A bookmark referencing another user's thread",
      "key": "tid",
      "record": {
        "type": "object",
        "required": ["subject", "createdAt"],
        "properties": {
          "subject": {
            "type": "string",
            "format": "at-uri",
            "description": "AT URI of the bookmarked thread"
          },
          "createdAt": {
            "type": "string",
            "format": "datetime",
            "description": "Bookmark timestamp"
          }
        }
      }
    }
  }
}
