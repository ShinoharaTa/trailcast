---
import "../styles/global.css";

interface Props {
  title: string;
  fullscreen?: boolean;
}

const { title, fullscreen = false } = Astro.props;
---

<!doctype html>
<html lang="ja">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>{title} - Trailcast Mock</title>
    <link
      href="https://fonts.googleapis.com/css2?family=Inter:wght@400;500;600;700&family=Noto+Sans+JP:wght@400;500;600;700&display=swap"
      rel="stylesheet"
    />
  </head>
  <body
    class:list={[
      "font-[Inter,_'Noto_Sans_JP',_sans-serif] antialiased",
      fullscreen
        ? "bg-surface-950 text-white"
        : "bg-surface-50 text-surface-900",
    ]}
  >
    {
      !fullscreen && (
        <nav class="sticky top-0 z-50 border-b border-surface-200 bg-white/80 backdrop-blur-md">
          <div class="mx-auto flex h-14 max-w-7xl items-center justify-between px-4">
            <a href="/" class="text-lg font-bold tracking-tight text-primary-600">
              Trailcast
            </a>
            <a
              href="/"
              class="text-sm text-surface-500 hover:text-surface-700"
            >
              Mock Index
            </a>
          </div>
        </nav>
      )
    }
    <slot />
  </body>
</html>
