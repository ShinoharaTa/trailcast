---
import Layout from "../layouts/Layout.astro";
import { thread, publicThread, threadList, bookmarks, blueskyPosts } from "../data/mock.ts";

const selectedCount = blueskyPosts.filter((p) => p.selected).length;

const pubAuthors = [...new Map(publicThread.checkpoints.map((c) => [c.author, c.authorAvatar]))];

const authorDot: Record<string, string> = {
  shino3: "bg-indigo-500",
  yuki: "bg-amber-500",
  taro: "bg-emerald-500",
};
---

<Layout title="Pattern 5: Dynamic Chronicle" fullscreen>

  {/* ───────── login ───────── */}
  <section data-screen="login" class="hidden">
    <div class="flex min-h-screen items-center justify-center px-4">
      <div class="relative w-full max-w-md overflow-hidden rounded-3xl bg-surface-900 shadow-2xl shadow-indigo-500/10">
        <div class="absolute inset-0 bg-gradient-to-br from-indigo-600/20 via-transparent to-violet-600/20 pointer-events-none" />
        <div class="relative px-8 py-12 text-center">
          <div class="mx-auto mb-5 flex size-14 items-center justify-center rounded-2xl bg-indigo-500 shadow-lg shadow-indigo-500/30">
            <svg class="size-7 text-white" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2"><path stroke-linecap="round" stroke-linejoin="round" d="M9 20l-5.447-2.724A1 1 0 013 16.382V5.618a1 1 0 011.447-.894L9 7m0 13l6-3m-6 3V7m6 10l4.553 2.276A1 1 0 0021 18.382V7.618a1 1 0 00-.553-.894L15 4m0 13V4m0 0L9 7" /></svg>
          </div>
          <h1 class="text-3xl font-bold tracking-tight text-white">Trailcast</h1>
          <p class="mt-2 text-sm text-white/50">旅の記録を、ダイナミックに残す</p>

          <div class="mt-10 space-y-4 text-left">
            <div>
              <label class="mb-1.5 block text-xs font-medium text-white/60">ハンドル</label>
              <input type="text" placeholder="yourname.bsky.social"
                class="w-full rounded-xl border border-white/10 bg-white/5 px-4 py-3 text-sm text-white placeholder-white/30 outline-none transition focus:border-indigo-400 focus:ring-2 focus:ring-indigo-400/20" />
            </div>
            <button data-goto="home"
              class="w-full rounded-xl bg-gradient-to-r from-indigo-500 to-violet-500 px-4 py-3 text-sm font-bold text-white shadow-lg shadow-indigo-500/25 transition hover:shadow-xl hover:brightness-110 active:scale-[0.98]">
              ログイン
            </button>
          </div>
          <p class="mt-6 text-xs text-white/30">AT Protocol で認証します</p>
        </div>
      </div>
    </div>
  </section>

  {/* ───────── home ───────── */}
  <section data-screen="home" class="hidden">
    <div class="mx-auto max-w-5xl px-4 py-8">
      <div class="mb-8 flex flex-wrap items-end justify-between gap-4">
        <div>
          <h2 class="text-3xl font-bold tracking-tight text-white">Chronicle</h2>
          <p class="mt-1 text-sm text-white/40">あなたの旅の記録</p>
        </div>
        <button data-goto="thread-create"
          class="flex items-center gap-2 rounded-xl bg-indigo-500 px-5 py-2.5 text-sm font-semibold text-white shadow-lg shadow-indigo-500/25 transition hover:bg-indigo-400">
          <svg class="size-4" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2.5"><path stroke-linecap="round" stroke-linejoin="round" d="M12 4v16m8-8H4" /></svg>
          新しいスレッド
        </button>
      </div>

      <div class="mb-6 flex gap-1 rounded-xl bg-white/5 p-1">
        <button id="tab-threads" class="flex-1 rounded-lg bg-white/10 px-4 py-2 text-sm font-semibold text-white shadow-sm">スレッド</button>
        <button id="tab-bookmarks" class="flex-1 rounded-lg px-4 py-2 text-sm font-medium text-white/40 transition hover:text-white/70">ブックマーク</button>
      </div>

      <div id="view-threads" class="grid gap-4 sm:grid-cols-2">
        {threadList.map((t, idx) => (
          <div
            data-goto={idx === 0 ? "thread-private" : idx === 1 ? "thread-public" : undefined}
            class:list={[
              "group relative overflow-hidden rounded-2xl bg-surface-800 shadow-lg transition-all duration-300 hover:shadow-xl hover:scale-[1.01]",
              idx <= 1 && "cursor-pointer",
            ]}
          >
            <div class="aspect-[16/9] overflow-hidden">
              <img src={t.coverImage} alt={t.title} class="h-full w-full object-cover transition-transform duration-700 group-hover:scale-105" loading="lazy" />
              <div class="pointer-events-none absolute inset-0 bg-gradient-to-t from-surface-900 via-surface-900/40 to-transparent" />
            </div>
            <div class="absolute inset-x-0 bottom-0 p-5">
              <div class="mb-2 flex items-center gap-2">
                <span class:list={[
                  "rounded-full px-2.5 py-0.5 text-[10px] font-bold uppercase tracking-wider",
                  t.visibility === "public" ? "bg-emerald-500/20 text-emerald-400" : "bg-white/10 text-white/50",
                ]}>
                  {t.visibility === "public" ? "Public" : "Private"}
                </span>
                {t.checkpoints.length > 0 && (
                  <span class="text-xs text-white/40">{t.checkpoints.length} checkpoints</span>
                )}
              </div>
              <h3 class="text-lg font-bold text-white">{t.title}</h3>
              <p class="mt-1 line-clamp-2 text-sm text-white/50">{t.description}</p>
            </div>
          </div>
        ))}
      </div>

      <div id="view-bookmarks" class="hidden grid gap-4 sm:grid-cols-2">
        {bookmarks.map((bm) => (
          <div class="group flex gap-4 rounded-2xl bg-surface-800 p-4 transition hover:bg-surface-700 cursor-pointer" data-goto="thread-public">
            <img src={bm.thread.coverImage} alt={bm.thread.title} class="size-20 shrink-0 rounded-xl object-cover" loading="lazy" />
            <div class="min-w-0 flex-1">
              <h3 class="truncate font-semibold text-white">{bm.thread.title}</h3>
              <p class="mt-1 text-sm text-white/40">{bm.thread.description}</p>
              <div class="mt-2 flex items-center gap-2 text-xs text-white/30">
                <img src={bm.thread.authorAvatar} alt={bm.thread.author} class="size-4 rounded-full" />
                <span>{bm.thread.author}</span>
              </div>
            </div>
          </div>
        ))}
      </div>
    </div>
  </section>

  {/* ───────── thread-create ───────── */}
  <section data-screen="thread-create" class="hidden">
    <div class="mx-auto max-w-2xl px-4 py-8">
      <button data-back class="mb-6 flex items-center gap-1.5 text-sm font-medium text-indigo-400 transition hover:text-indigo-300">
        <svg class="size-4" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2.5"><path stroke-linecap="round" stroke-linejoin="round" d="M15 19l-7-7 7-7" /></svg>
        戻る
      </button>
      <div class="rounded-2xl bg-surface-800 p-6 shadow-lg sm:p-8">
        <h2 class="mb-6 text-xl font-bold text-white">新しいスレッドを作成</h2>
        <div class="space-y-5">
          <div>
            <label class="mb-1.5 block text-xs font-medium text-white/50">タイトル</label>
            <input type="text" placeholder="例: 京都日帰り旅" class="w-full rounded-xl border border-white/10 bg-white/5 px-4 py-3 text-sm text-white placeholder-white/20 outline-none focus:border-indigo-400 focus:ring-2 focus:ring-indigo-400/20" />
          </div>
          <div>
            <label class="mb-1.5 block text-xs font-medium text-white/50">概要</label>
            <textarea rows="3" placeholder="どんなスレッド？" class="w-full resize-none rounded-xl border border-white/10 bg-white/5 px-4 py-3 text-sm text-white placeholder-white/20 outline-none focus:border-indigo-400 focus:ring-2 focus:ring-indigo-400/20"></textarea>
          </div>
          <div class="flex items-center justify-between rounded-xl border border-white/10 bg-white/5 px-4 py-3">
            <span class="text-sm text-white/70">公開設定</span>
            <div class="flex items-center gap-2">
              <span class="text-xs text-white/40">Private</span>
              <div class="h-6 w-11 rounded-full bg-surface-700 p-0.5">
                <div class="size-5 rounded-full bg-white/40 shadow transition" />
              </div>
            </div>
          </div>
          <div class="flex aspect-[16/9] items-center justify-center rounded-xl border-2 border-dashed border-white/10 bg-white/[0.02] transition hover:border-indigo-400/40">
            <div class="text-center">
              <svg class="mx-auto size-8 text-white/20" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="1.5"><path stroke-linecap="round" stroke-linejoin="round" d="M2.25 15.75l5.159-5.159a2.25 2.25 0 013.182 0l5.159 5.159m-1.5-1.5l1.409-1.409a2.25 2.25 0 013.182 0l2.909 2.909M6.75 6.75h.008v.008H6.75V6.75z" /></svg>
              <span class="mt-2 block text-xs text-white/30">カバー画像を選択</span>
            </div>
          </div>
          <button data-goto="home" class="w-full rounded-xl bg-gradient-to-r from-indigo-500 to-violet-500 py-3 text-sm font-bold text-white shadow-lg shadow-indigo-500/25 transition hover:shadow-xl hover:brightness-110">
            作成
          </button>
        </div>
      </div>
    </div>
  </section>

  {/* ───────── thread-private ───────── */}
  <section data-screen="thread-private" class="hidden">
    {/* Hero cover */}
    <div class="relative h-[50vh] min-h-[320px] overflow-hidden">
      <img src={thread.coverImage} alt={thread.title} class="h-full w-full object-cover" />
      <div class="absolute inset-0 bg-gradient-to-t from-surface-950 via-surface-950/50 to-surface-950/20" />
      <div class="absolute inset-x-0 bottom-0 mx-auto max-w-3xl px-5 pb-8">
        <button data-back class="mb-4 flex items-center gap-1.5 text-sm font-medium text-white/60 transition hover:text-white">
          <svg class="size-4" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2.5"><path stroke-linecap="round" stroke-linejoin="round" d="M15 19l-7-7 7-7" /></svg>
          スレッド一覧
        </button>
        <div class="flex items-center gap-2 mb-3">
          <span class="rounded-full bg-white/10 px-3 py-0.5 text-[11px] font-bold text-white/60 backdrop-blur-sm">Private</span>
          <span class="text-xs text-white/40">{thread.createdAt}</span>
        </div>
        <h1 class="text-3xl font-bold tracking-tight text-white sm:text-4xl">{thread.title}</h1>
        <p class="mt-3 max-w-xl text-base leading-relaxed text-white/60">{thread.description}</p>
        <div class="mt-4 flex items-center gap-3">
          <img src={thread.authorAvatar} alt={thread.author} class="size-8 rounded-full ring-2 ring-white/20" />
          <span class="text-sm font-medium text-white/80">@{thread.author}</span>
        </div>
      </div>
    </div>

    {/* Action bar */}
    <div class="sticky top-14 z-30 border-b border-white/5 bg-surface-950/80 backdrop-blur-xl">
      <div class="mx-auto flex max-w-3xl items-center gap-2 overflow-x-auto px-5 py-3">
        <button data-goto="share" class="shrink-0 rounded-lg bg-white/5 px-3.5 py-2 text-xs font-medium text-white/70 transition hover:bg-white/10">共有</button>
        <button data-goto="bsky-crosspost" class="shrink-0 rounded-lg bg-[#0085ff]/10 px-3.5 py-2 text-xs font-medium text-[#0085ff] transition hover:bg-[#0085ff]/20">Blueskyに投稿</button>
        <button data-goto="bsky-import" class="shrink-0 rounded-lg bg-white/5 px-3.5 py-2 text-xs font-medium text-white/70 transition hover:bg-white/10">インポート</button>
      </div>
    </div>

    {/* Timeline */}
    <div class="mx-auto max-w-3xl px-5 py-10">
      {thread.checkpoints.map((cp, i) => (
        <div class="group relative">
          {/* Timeline connector */}
          <div class="absolute left-5 top-0 bottom-0 w-px bg-gradient-to-b from-indigo-500/40 to-violet-500/40 sm:left-6" />
          <div class="absolute left-[14px] top-3 size-3 rounded-full border-2 border-indigo-400 bg-surface-950 sm:left-[18px]" />

          <div class="pb-10 pl-12 sm:pl-16">
            {/* Time & location header */}
            <div class="mb-3 flex flex-wrap items-center gap-x-3 gap-y-1 text-xs">
              <span class="font-mono font-bold text-indigo-400">{cp.time}</span>
              {cp.location && (
                <span class="flex items-center gap-1 text-white/40">
                  <svg class="size-3" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2"><path stroke-linecap="round" stroke-linejoin="round" d="M15 10.5a3 3 0 11-6 0 3 3 0 016 0z" /><path stroke-linecap="round" stroke-linejoin="round" d="M19.5 10.5c0 7.142-7.5 11.25-7.5 11.25S4.5 17.642 4.5 10.5a7.5 7.5 0 0115 0z" /></svg>
                  {cp.location}
                </span>
              )}
              <button data-goto="checkpoint-edit" class="ml-auto rounded-md px-2 py-1 text-white/20 opacity-0 transition group-hover:opacity-100 hover:bg-white/5 hover:text-white/60">
                <svg class="size-3.5" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2"><path stroke-linecap="round" stroke-linejoin="round" d="M16.862 4.487l1.687-1.688a1.875 1.875 0 112.652 2.652L6.832 19.82a4.5 4.5 0 01-1.897 1.13l-2.685.8.8-2.685a4.5 4.5 0 011.13-1.897L16.863 4.487z" /></svg>
              </button>
            </div>

            {cp.images.length > 0 ? (
              <Fragment>
                {/* Photo checkpoint: editorial style */}
                {cp.images.length === 1 ? (
                  <div class="overflow-hidden rounded-2xl">
                    <img src={cp.images[0]} alt="" class="aspect-[16/9] w-full object-cover transition-transform duration-500 group-hover:scale-[1.02]" loading="lazy" />
                  </div>
                ) : cp.images.length === 2 ? (
                  <div class="grid grid-cols-2 gap-1.5 overflow-hidden rounded-2xl">
                    {cp.images.map((img) => (
                      <img src={img} alt="" class="aspect-[4/3] w-full object-cover" loading="lazy" />
                    ))}
                  </div>
                ) : (
                  <div class="grid grid-cols-3 gap-1.5 overflow-hidden rounded-2xl">
                    <div class="col-span-2 row-span-2">
                      <img src={cp.images[0]} alt="" class="h-full w-full object-cover" loading="lazy" />
                    </div>
                    {cp.images.slice(1, 3).map((img) => (
                      <img src={img} alt="" class="aspect-square w-full object-cover" loading="lazy" />
                    ))}
                    {cp.images.length > 3 && (
                      <div class="col-span-3 grid grid-cols-2 gap-1.5">
                        {cp.images.slice(3).map((img) => (
                          <img src={img} alt="" class="aspect-[16/9] w-full object-cover" loading="lazy" />
                        ))}
                      </div>
                    )}
                  </div>
                )}
                <p class="mt-4 text-base leading-relaxed text-white/70">{cp.text}</p>
              </Fragment>
            ) : (
              <Fragment>
                {/* Text-only checkpoint: styled quote card */}
                <div class="rounded-2xl border border-white/5 bg-gradient-to-br from-white/[0.04] to-white/[0.01] p-5">
                  <p class="text-lg leading-relaxed text-white/80">{cp.text}</p>
                </div>
              </Fragment>
            )}
          </div>
        </div>
      ))}

      {/* End marker */}
      <div class="flex items-center gap-3 pl-12 sm:pl-16">
        <div class="h-px flex-1 bg-gradient-to-r from-indigo-500/30 to-transparent" />
        <span class="text-xs text-white/30">{thread.checkpoints.length} チェックポイント</span>
      </div>

      <div class="mt-8 pl-12 sm:pl-16">
        <button data-goto="checkpoint-post" class="w-full rounded-xl border border-dashed border-indigo-500/30 bg-indigo-500/5 py-4 text-sm font-medium text-indigo-400 transition hover:border-indigo-400 hover:bg-indigo-500/10">
          + チェックポイントを追加
        </button>
      </div>
    </div>
  </section>

  {/* ───────── thread-public ───────── */}
  <section data-screen="thread-public" class="hidden">
    <div class="relative h-[50vh] min-h-[320px] overflow-hidden">
      <img src={publicThread.coverImage} alt={publicThread.title} class="h-full w-full object-cover" />
      <div class="absolute inset-0 bg-gradient-to-t from-surface-950 via-surface-950/50 to-surface-950/20" />
      <div class="absolute inset-x-0 bottom-0 mx-auto max-w-3xl px-5 pb-8">
        <button data-back class="mb-4 flex items-center gap-1.5 text-sm font-medium text-white/60 transition hover:text-white">
          <svg class="size-4" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2.5"><path stroke-linecap="round" stroke-linejoin="round" d="M15 19l-7-7 7-7" /></svg>
          スレッド一覧
        </button>
        <div class="flex items-center gap-2 mb-3">
          <span class="rounded-full bg-emerald-500/20 px-3 py-0.5 text-[11px] font-bold text-emerald-400 backdrop-blur-sm">Public</span>
          <span class="text-xs text-white/40">{publicThread.createdAt}</span>
        </div>
        <h1 class="text-3xl font-bold tracking-tight text-white sm:text-4xl">{publicThread.title}</h1>
        <p class="mt-3 max-w-xl text-base leading-relaxed text-white/60">{publicThread.description}</p>
        <div class="mt-4 flex items-center gap-1">
          {pubAuthors.map(([author, avatar]) => (
            <img src={avatar} alt={author} class="size-8 rounded-full ring-2 ring-surface-950" title={author} />
          ))}
          <span class="ml-2 text-xs text-white/40">{pubAuthors.length} 人が参加</span>
        </div>
      </div>
    </div>

    <div class="sticky top-14 z-30 border-b border-white/5 bg-surface-950/80 backdrop-blur-xl">
      <div class="mx-auto flex max-w-3xl items-center gap-2 overflow-x-auto px-5 py-3">
        <button data-goto="share" class="shrink-0 rounded-lg bg-white/5 px-3.5 py-2 text-xs font-medium text-white/70 transition hover:bg-white/10">共有</button>
        <button data-goto="bsky-crosspost" class="shrink-0 rounded-lg bg-[#0085ff]/10 px-3.5 py-2 text-xs font-medium text-[#0085ff] transition hover:bg-[#0085ff]/20">Blueskyに投稿</button>
        <button data-goto="bsky-import" class="shrink-0 rounded-lg bg-white/5 px-3.5 py-2 text-xs font-medium text-white/70 transition hover:bg-white/10">インポート</button>
      </div>
    </div>

    <div class="mx-auto max-w-3xl px-5 py-10">
      {publicThread.checkpoints.map((cp, i) => {
        const dotColor = authorDot[cp.author] ?? "bg-white/40";
        return (
          <div class="group relative">
            <div class="absolute left-5 top-0 bottom-0 w-px bg-gradient-to-b from-indigo-500/40 to-violet-500/40 sm:left-6" />
            <div class={`absolute left-[14px] top-3 size-3 rounded-full ${dotColor} ring-2 ring-surface-950 sm:left-[18px]`} />

            <div class="pb-10 pl-12 sm:pl-16">
              <div class="mb-3 flex flex-wrap items-center gap-x-3 gap-y-1 text-xs">
                <div class="flex items-center gap-2">
                  <img src={cp.authorAvatar} alt={cp.author} class="size-5 rounded-full" />
                  <span class="font-medium text-white/60">@{cp.author}</span>
                </div>
                <span class="font-mono font-bold text-indigo-400">{cp.time}</span>
                {cp.location && (
                  <span class="flex items-center gap-1 text-white/40">
                    <svg class="size-3" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2"><path stroke-linecap="round" stroke-linejoin="round" d="M15 10.5a3 3 0 11-6 0 3 3 0 016 0z" /><path stroke-linecap="round" stroke-linejoin="round" d="M19.5 10.5c0 7.142-7.5 11.25-7.5 11.25S4.5 17.642 4.5 10.5a7.5 7.5 0 0115 0z" /></svg>
                    {cp.location}
                  </span>
                )}
              </div>

              {cp.images.length > 0 ? (
                <Fragment>
                  <div class="grid gap-1.5 overflow-hidden rounded-2xl" style={`grid-template-columns: repeat(${Math.min(cp.images.length, 2)}, 1fr)`}>
                    {cp.images.map((img) => (
                      <img src={img} alt="" class:list={["w-full object-cover", cp.images.length === 1 ? "aspect-[16/9]" : "aspect-[4/3]"]} loading="lazy" />
                    ))}
                  </div>
                  <p class="mt-4 text-base leading-relaxed text-white/70">{cp.text}</p>
                </Fragment>
              ) : (
                <div class="rounded-2xl border border-white/5 bg-gradient-to-br from-white/[0.04] to-white/[0.01] p-5">
                  <p class="text-lg leading-relaxed text-white/80">{cp.text}</p>
                </div>
              )}
            </div>
          </div>
        );
      })}

      <div class="flex items-center gap-3 pl-12 sm:pl-16">
        <div class="h-px flex-1 bg-gradient-to-r from-indigo-500/30 to-transparent" />
        <span class="text-xs text-white/30">{publicThread.checkpoints.length} チェックポイント</span>
      </div>

      <div class="mt-8 pl-12 sm:pl-16">
        <button data-goto="checkpoint-post" class="w-full rounded-xl border border-dashed border-indigo-500/30 bg-indigo-500/5 py-4 text-sm font-medium text-indigo-400 transition hover:border-indigo-400 hover:bg-indigo-500/10">
          + チェックポイントを追加
        </button>
      </div>
    </div>
  </section>

  {/* ───────── checkpoint-post ───────── */}
  <section data-screen="checkpoint-post" class="hidden">
    <div class="mx-auto max-w-2xl px-4 py-8">
      <button data-back class="mb-6 flex items-center gap-1.5 text-sm font-medium text-indigo-400 transition hover:text-indigo-300">
        <svg class="size-4" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2.5"><path stroke-linecap="round" stroke-linejoin="round" d="M15 19l-7-7 7-7" /></svg>
        スレッドに戻る
      </button>

      <div class="rounded-2xl bg-surface-800 p-6 shadow-lg sm:p-8">
        <h2 class="mb-6 text-lg font-bold text-white">チェックポイントを追加</h2>
        <div class="space-y-5">
          <div class="relative">
            <textarea rows="4" placeholder="何があった？" class="w-full resize-none rounded-xl border border-white/10 bg-white/5 px-4 py-3 text-sm text-white placeholder-white/20 outline-none focus:border-indigo-400 focus:ring-2 focus:ring-indigo-400/20"></textarea>
            <span class="absolute bottom-3 right-3 text-xs text-white/20">0/200</span>
          </div>

          <div>
            <label class="mb-2 block text-xs font-medium text-white/50">写真</label>
            <div class="grid grid-cols-4 gap-2">
              {[0,1,2,3].map((i) => (
                <div class="flex aspect-square items-center justify-center rounded-xl border border-dashed border-white/10 bg-white/[0.02] transition hover:border-indigo-400/40">
