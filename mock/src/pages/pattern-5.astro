<style>
  @keyframes fadeIn { from { opacity: 0; transform: translateY(8px); } to { opacity: 1; transform: translateY(0); } }
  .animate-fade-in { animation: fadeIn 0.25s ease-out; }
</style>

<script>
  const screens = document.querySelectorAll<HTMLElement>('[data-screen]');
  const history: string[] = ['login'];

  function show(id: string, pushHistory = true) {
    screens.forEach(s => s.classList.add('hidden'));
    const target = document.querySelector<HTMLElement>(`[data-screen="${id}"]`);
    if (target) {
      target.classList.remove('hidden');
      target.classList.add('animate-fade-in');
      setTimeout(() => target.classList.remove('animate-fade-in'), 300);
      window.scrollTo(0, 0);
    }
    if (pushHistory && history[history.length - 1] !== id) history.push(id);
  }

  document.addEventListener('click', (e) => {
    const btn = (e.target as HTMLElement).closest('[data-goto]') as HTMLElement;
    if (btn) { show(btn.dataset.goto!); return; }
    const back = (e.target as HTMLElement).closest('[data-back]') as HTMLElement;
    if (back) { history.pop(); show(history[history.length - 1] || 'login', false); }
  });

  const tabThreads = document.getElementById('tab-threads');
  const tabBookmarks = document.getElementById('tab-bookmarks');
  const viewThreads = document.getElementById('view-threads');
  const viewBookmarks = document.getElementById('view-bookmarks');

  const onCls = ['bg-white/10', 'text-white', 'font-semibold', 'shadow-sm'];
  const offCls = ['text-white/40', 'font-medium'];

  tabThreads?.addEventListener('click', () => {
    viewThreads?.classList.remove('hidden');
    viewBookmarks?.classList.add('hidden');
    onCls.forEach(c => tabThreads.classList.add(c));
    offCls.forEach(c => tabThreads.classList.remove(c));
    offCls.forEach(c => tabBookmarks?.classList.add(c));
    onCls.forEach(c => tabBookmarks?.classList.remove(c));
  });

  tabBookmarks?.addEventListener('click', () => {
    viewBookmarks?.classList.remove('hidden');
    viewThreads?.classList.add('hidden');
    onCls.forEach(c => tabBookmarks!.classList.add(c));
    offCls.forEach(c => tabBookmarks!.classList.remove(c));
    offCls.forEach(c => tabThreads?.classList.add(c));
    onCls.forEach(c => tabThreads?.classList.remove(c));
  });

  show('login', false);
</script>
