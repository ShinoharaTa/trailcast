---
import Layout from "../layouts/Layout.astro";
import {
  thread,
  publicThread,
  threadList,
  bookmarks,
  blueskyPosts,
} from "../data/mock.ts";

const fmt = (d: string) =>
  new Date(d).toLocaleDateString("ja-JP", {
    year: "numeric",
    month: "long",
    day: "numeric",
  });

const totalCp = thread.checkpoints.length;
const firstTime = thread.checkpoints[0]?.time ?? "";
const lastTime = thread.checkpoints[totalCp - 1]?.time ?? "";

const pubAuthors = [
  ...new Map(
    publicThread.checkpoints.map((c) => [c.author, c.authorAvatar])
  ),
];

const selectedCount = blueskyPosts.filter((p) => p.selected).length;
---

<Layout title="Pattern 3: Journal">

  {/* ================================================================
      login
      ================================================================ */}
  <section data-screen="login" class="hidden min-h-[80vh] flex items-center justify-center px-5 py-20">
    <div class="w-full max-w-sm">
      <div class="rounded-3xl border border-surface-200 bg-white p-10 shadow-xl shadow-amber-900/5 text-center">
        <h1 class="font-serif text-4xl tracking-tight text-surface-900">Trailcast</h1>
        <p class="mt-3 text-sm text-surface-400 leading-relaxed">旅の記録を、美しく残す</p>

        <div class="mt-10 space-y-4 text-left">
          <div>
            <label class="block text-xs font-medium text-surface-500 mb-1.5">ハンドル</label>
            <input
              type="text"
              placeholder="yourname.bsky.social"
              class="w-full rounded-xl border border-surface-200 bg-surface-50 px-4 py-3 text-sm text-surface-800 placeholder:text-surface-300 focus:border-amber-400 focus:ring-2 focus:ring-amber-100 focus:outline-none transition"
            />
          </div>
          <button
            data-goto="home"
            class="w-full rounded-xl bg-gradient-to-r from-amber-500 to-orange-500 px-6 py-3 text-sm font-semibold text-white shadow-lg shadow-amber-500/25 transition hover:shadow-xl hover:shadow-amber-500/30 active:scale-[0.98]"
          >
            ログイン
          </button>
        </div>

        <p class="mt-6 text-xs text-surface-300">AT Protocol でログイン</p>
      </div>
    </div>
  </section>

  {/* ================================================================
      home
      ================================================================ */}
  <section data-screen="home" class="hidden mx-auto max-w-[720px] px-5 py-10">
    <div class="flex items-end justify-between mb-10">
      <div>
        <h2 class="font-serif text-3xl tracking-tight text-surface-900">あなたの記録</h2>
        <p class="mt-1 text-sm text-surface-400">旅のスレッドを管理する</p>
      </div>
      <button
        data-goto="thread-create"
        class="inline-flex items-center gap-2 rounded-full bg-gradient-to-r from-amber-500 to-orange-500 px-5 py-2.5 text-sm font-semibold text-white shadow-lg shadow-amber-500/25 transition hover:shadow-xl active:scale-95"
      >
        <svg class="h-4 w-4" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2"><path stroke-linecap="round" stroke-linejoin="round" d="M12 4.5v15m7.5-7.5h-15" /></svg>
        新しいスレッド
      </button>
    </div>

    <!-- Tab toggle -->
    <div class="mb-8 flex gap-1 rounded-full bg-surface-100 p-1 max-w-xs">
      <button id="tab-threads" class="home-tab flex-1 rounded-full px-5 py-2 text-sm font-semibold transition bg-white text-amber-700 shadow-sm">スレッド</button>
      <button id="tab-bookmarks" class="home-tab flex-1 rounded-full px-5 py-2 text-sm font-medium transition text-surface-500 hover:text-surface-700">ブックマーク</button>
    </div>

    <!-- Thread list -->
    <div id="panel-threads" class="space-y-10">
      {threadList.map((t, idx) => (
        <article
          data-goto={idx === 0 ? "thread-private" : idx === 1 ? "thread-public" : undefined}
          class:list={["group cursor-pointer", (idx === 0 || idx === 1) && "hover:opacity-90 transition"]}
        >
          <div class="overflow-hidden rounded-2xl">
            <img
              src={t.coverImage}
              alt={t.title}
              class="aspect-[16/9] w-full object-cover transition-transform duration-700 group-hover:scale-[1.03]"
              loading="lazy"
            />
          </div>
          <div class="mt-5">
            <h3 class="font-serif text-2xl tracking-tight text-surface-900 group-hover:text-amber-700 transition">{t.title}</h3>
            <p class="mt-2 text-base leading-relaxed text-surface-500">{t.description}</p>
            <div class="mt-3 flex items-center gap-3 text-xs text-surface-400">
              <span>{fmt(t.createdAt)}</span>
              <span class:list={[
                "rounded-full px-2.5 py-0.5 font-medium",
                t.visibility === "public"
                  ? "bg-emerald-50 text-emerald-600"
                  : "bg-surface-100 text-surface-500",
              ]}>
                {t.visibility === "public" ? "Public" : "Private"}
              </span>
              {t.checkpoints.length > 0 && (
                <span>{t.checkpoints.length} checkpoints</span>
              )}
            </div>
          </div>
        </article>
      ))}
    </div>

    <!-- Bookmark list -->
    <div id="panel-bookmarks" class="hidden space-y-6">
      {bookmarks.map((bm) => (
        <div class="flex gap-5 items-start group">
          <img src={bm.thread.coverImage} alt={bm.thread.title} class="w-28 aspect-[16/10] rounded-xl object-cover shrink-0" loading="lazy" />
          <div>
            <h4 class="font-semibold text-surface-800 group-hover:text-amber-700 transition">{bm.thread.title}</h4>
            <p class="mt-1 text-sm text-surface-400">{bm.thread.description}</p>
            <div class="mt-2 flex items-center gap-2 text-xs text-surface-400">
              <img src={bm.thread.authorAvatar} alt={bm.thread.author} class="h-4 w-4 rounded-full object-cover" />
              <span>{bm.thread.author}</span>
              <span>·</span>
              <span>保存日: {fmt(bm.createdAt)}</span>
            </div>
          </div>
        </div>
      ))}
    </div>
  </section>

  {/* ================================================================
      thread-create
      ================================================================ */}
  <section data-screen="thread-create" class="hidden mx-auto max-w-[720px] px-5 py-10">
    <button data-back class="inline-flex items-center gap-1 text-sm font-medium text-surface-500 hover:text-amber-600 transition mb-8">
      <svg class="h-4 w-4" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2"><path stroke-linecap="round" stroke-linejoin="round" d="M15.75 19.5 8.25 12l7.5-7.5" /></svg>
      戻る
    </button>

    <h2 class="font-serif text-2xl tracking-tight text-surface-900 mb-8">新しいスレッドを作成</h2>

    <div class="space-y-6">
      <div>
        <input
          type="text"
          placeholder="タイトルを入力…"
          class="w-full border-0 border-b-2 border-surface-200 bg-transparent px-0 py-3 font-serif text-2xl text-surface-900 placeholder:text-surface-300 focus:border-amber-400 focus:ring-0 focus:outline-none transition"
        />
      </div>

      <div>
        <textarea
          placeholder="このスレッドについて書く…"
          rows="3"
          class="w-full rounded-xl border border-surface-200 bg-surface-50 px-4 py-3 text-sm text-surface-700 placeholder:text-surface-300 focus:border-amber-400 focus:ring-2 focus:ring-amber-100 focus:outline-none resize-none transition"
        ></textarea>
      </div>

      <div>
        <label class="block text-xs font-medium text-surface-500 mb-3">公開設定</label>
        <div class="inline-flex rounded-full border border-surface-200 p-1 bg-surface-50">
          <button class="rounded-full bg-amber-500 px-5 py-2 text-sm font-semibold text-white shadow-sm transition">Private</button>
          <button class="rounded-full px-5 py-2 text-sm font-medium text-surface-500 transition hover:text-surface-700">Public</button>
        </div>
      </div>

      <div>
        <label class="block text-xs font-medium text-surface-500 mb-3">カバー画像</label>
        <div class="flex aspect-[16/7] items-center justify-center rounded-2xl border-2 border-dashed border-surface-200 bg-surface-50 transition hover:border-amber-300 hover:bg-amber-50/30 cursor-pointer">
          <div class="text-center">
            <svg class="mx-auto h-10 w-10 text-surface-300" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="1.5">
              <path stroke-linecap="round" stroke-linejoin="round" d="m2.25 15.75 5.159-5.159a2.25 2.25 0 0 1 3.182 0l5.159 5.159m-1.5-1.5 1.409-1.409a2.25 2.25 0 0 1 3.182 0l2.909 2.909M3.75 21h16.5A2.25 2.25 0 0 0 22.5 18.75V5.25A2.25 2.25 0 0 0 20.25 3H3.75A2.25 2.25 0 0 0 1.5 5.25v13.5A2.25 2.25 0 0 0 3.75 21Z" />
            </svg>
            <p class="mt-2 text-sm text-surface-400">クリックまたはドロップで画像を追加</p>
          </div>
        </div>
      </div>

      <div class="pt-4">
        <button
          data-goto="home"
          class="w-full rounded-xl bg-gradient-to-r from-amber-500 to-orange-500 px-6 py-3.5 text-sm font-semibold text-white shadow-lg shadow-amber-500/25 transition hover:shadow-xl active:scale-[0.98]"
        >
          作成
        </button>
      </div>
    </div>
  </section>

  {/* ================================================================
      thread-private
      ================================================================ */}
  <section data-screen="thread-private" class="hidden">
    <article class="mx-auto max-w-[720px] px-5 py-10">
      <button data-back class="inline-flex items-center gap-1 text-sm font-medium text-surface-500 hover:text-amber-600 transition mb-8">
        <svg class="h-4 w-4" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2"><path stroke-linecap="round" stroke-linejoin="round" d="M15.75 19.5 8.25 12l7.5-7.5" /></svg>
        戻る
      </button>

      <!-- Hero -->
      <div class="overflow-hidden rounded-2xl sm:rounded-3xl">
        <img
          src={thread.coverImage}
          alt={thread.title}
          class="aspect-[16/9] w-full object-cover transition-transform duration-700 hover:scale-[1.02]"
          loading="eager"
        />
      </div>

      <!-- Title -->
      <h1 class="mt-8 font-serif text-4xl leading-tight tracking-tight text-surface-900 sm:text-5xl sm:leading-[1.15]">
        {thread.title}
      </h1>
      <p class="mt-4 text-lg leading-relaxed text-surface-500 sm:text-xl">{thread.description}</p>

      <!-- Author & Meta -->
      <div class="mt-8 flex flex-wrap items-center gap-4">
        <div class="flex items-center gap-3">
          <img src={thread.authorAvatar} alt={thread.author} class="h-11 w-11 rounded-full object-cover ring-2 ring-amber-100" />
          <div>
            <p class="text-sm font-semibold text-surface-800">{thread.author}</p>
            <p class="text-xs text-surface-400">{fmt(thread.createdAt)}</p>
          </div>
        </div>
        <div class="flex items-center gap-2 text-xs">
          <span class="inline-flex items-center gap-1 rounded-full bg-amber-50 px-2.5 py-1 text-amber-700 ring-1 ring-amber-200/60">
            <svg class="h-3.5 w-3.5" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2"><path stroke-linecap="round" stroke-linejoin="round" d="M12 6v6l4 2" /><circle cx="12" cy="12" r="10" /></svg>
            {firstTime} – {lastTime}
          </span>
          <span class="inline-flex items-center gap-1 rounded-full bg-surface-100 px-2.5 py-1 text-surface-500">
            <svg class="h-3.5 w-3.5" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2"><path stroke-linecap="round" stroke-linejoin="round" d="M15 10.5a3 3 0 1 1-6 0 3 3 0 0 1 6 0Z" /><path stroke-linecap="round" stroke-linejoin="round" d="M19.5 10.5c0 7.142-7.5 11.25-7.5 11.25S4.5 17.642 4.5 10.5a7.5 7.5 0 0 1 15 0Z" /></svg>
            {totalCp} スポット
          </span>
        </div>
      </div>

      <!-- Action buttons -->
      <div class="mt-6 flex flex-wrap gap-2">
        <button data-goto="share" class="inline-flex items-center gap-1.5 rounded-full border border-surface-200 bg-white px-4 py-2 text-sm font-medium text-surface-600 shadow-sm transition hover:border-amber-300 hover:text-amber-700 hover:shadow active:scale-95">
          <svg class="h-4 w-4" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2"><path stroke-linecap="round" stroke-linejoin="round" d="M7.217 10.907a2.25 2.25 0 1 0 0 2.186m0-2.186c.18.324.283.696.283 1.093s-.103.77-.283 1.093m0-2.186 9.566-5.314m-9.566 7.5 9.566 5.314m0-12.814a2.25 2.25 0 1 0 3.935-2.186 2.25 2.25 0 0 0-3.935 2.186Zm0 12.814a2.25 2.25 0 1 0 3.933 2.185 2.25 2.25 0 0 0-3.933-2.185Z" /></svg>
          共有
        </button>
        <button data-goto="bsky-crosspost" class="inline-flex items-center gap-1.5 rounded-full border border-surface-200 bg-white px-4 py-2 text-sm font-medium text-surface-600 shadow-sm transition hover:border-amber-300 hover:text-amber-700 hover:shadow active:scale-95">
          <svg class="h-4 w-4 text-sky-500" viewBox="0 0 24 24" fill="currentColor"><path d="M12 10.8c-1.087-2.114-4.046-6.053-6.798-7.995C2.566.944 1.561 1.266.902 1.565.139 1.908 0 3.08 0 3.768c0 .69.378 5.65.6 6.463.785 2.878 3.592 3.614 6.14 3.192-3.836.649-8.084 2.124-3.24 7.529C8.075 25.586 10.447 19.065 12 16.14c1.553 2.924 3.075 9.283 8.5 4.812 4.844-5.405.596-6.88-3.24-7.53 2.548.423 5.355-.313 6.14-3.19.222-.814.6-5.774.6-6.464 0-.688-.139-1.86-.902-2.203-.659-.3-1.664-.62-4.3 1.24C16.046 4.748 13.087 8.687 12 10.8Z" /></svg>
          Blueskyに投稿
        </button>
        <button data-goto="bsky-import" class="inline-flex items-center gap-1.5 rounded-full border border-surface-200 bg-white px-4 py-2 text-sm font-medium text-surface-600 shadow-sm transition hover:border-amber-300 hover:text-amber-700 hover:shadow active:scale-95">
          <svg class="h-4 w-4" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2"><path stroke-linecap="round" stroke-linejoin="round" d="M3 16.5v2.25A2.25 2.25 0 0 0 5.25 21h13.5A2.25 2.25 0 0 0 21 18.75V16.5m-13.5-9L12 3m0 0 4.5 4.5M12 3v13.5" /></svg>
          インポート
        </button>
      </div>

      <div class="mt-10 h-px bg-gradient-to-r from-transparent via-amber-200 to-transparent"></div>

      <!-- Checkpoints -->
      {thread.checkpoints.map((cp, idx) => (
        <section class:list={["relative", idx === 0 ? "mt-12" : "mt-16"]}>
          <div class="mb-5 flex items-center justify-between">
            <div class="flex items-center gap-3">
              <span class="inline-flex items-center gap-1.5 rounded-full bg-amber-50 px-3 py-1 text-sm font-semibold tabular-nums text-amber-700 ring-1 ring-amber-200/60">
                <svg class="h-3.5 w-3.5 text-amber-500" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2.5"><path stroke-linecap="round" stroke-linejoin="round" d="M12 6v6l4 2" /><circle cx="12" cy="12" r="10" /></svg>
                {cp.time}
              </span>
              {cp.location && (
                <span class="inline-flex items-center gap-1 text-sm text-surface-400">
                  <svg class="h-3.5 w-3.5" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2"><path stroke-linecap="round" stroke-linejoin="round" d="M15 10.5a3 3 0 1 1-6 0 3 3 0 0 1 6 0Z" /><path stroke-linecap="round" stroke-linejoin="round" d="M19.5 10.5c0 7.142-7.5 11.25-7.5 11.25S4.5 17.642 4.5 10.5a7.5 7.5 0 0 1 15 0Z" /></svg>
                  {cp.location}
                </span>
              )}
            </div>
            <button data-goto="checkpoint-edit" class="flex h-8 w-8 items-center justify-center rounded-full text-surface-300 transition hover:bg-amber-50 hover:text-amber-600">
              <svg class="h-4 w-4" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2"><path stroke-linecap="round" stroke-linejoin="round" d="m16.862 4.487 1.687-1.688a1.875 1.875 0 1 1 2.652 2.652L10.582 16.07a4.5 4.5 0 0 1-1.897 1.13L6 18l.8-2.685a4.5 4.5 0 0 1 1.13-1.897l8.932-8.931Zm0 0L19.5 7.125" /></svg>
            </button>
          </div>

          {/* Images */}
          {cp.images.length === 1 && (
            <div class="mb-5 overflow-hidden rounded-xl sm:rounded-2xl">
              <img src={cp.images[0]} alt="" class="w-full object-cover transition-transform duration-500 hover:scale-[1.015]" loading="lazy" />
            </div>
          )}
          {cp.images.length === 2 && (
            <div class="mb-5 grid grid-cols-2 gap-2 sm:gap-3">
              {cp.images.map((img) => (
                <div class="overflow-hidden rounded-xl sm:rounded-2xl">
                  <img src={img} alt="" class="aspect-[4/3] w-full object-cover transition-transform duration-500 hover:scale-[1.03]" loading="lazy" />
                </div>
              ))}
            </div>
          )}
          {cp.images.length === 3 && (
            <div class="mb-5 grid grid-cols-3 gap-2 sm:gap-3">
              <div class="col-span-2 overflow-hidden rounded-xl sm:rounded-2xl">
                <img src={cp.images[0]} alt="" class="aspect-[4/3] w-full object-cover transition-transform duration-500 hover:scale-[1.03]" loading="lazy" />
              </div>
              <div class="flex flex-col gap-2 sm:gap-3">
                {cp.images.slice(1).map((img) => (
                  <div class="overflow-hidden rounded-xl sm:rounded-2xl">
                    <img src={img} alt="" class="aspect-square w-full object-cover transition-transform duration-500 hover:scale-[1.03]" loading="lazy" />
                  </div>
                ))}
              </div>
            </div>
          )}
          {cp.images.length >= 4 && (
            <div class="mb-5 grid grid-cols-2 gap-2 sm:gap-3">
              {cp.images.map((img, imgIdx) => (
                <div class:list={["overflow-hidden rounded-xl sm:rounded-2xl", imgIdx === 0 && cp.images.length % 2 !== 0 ? "col-span-2" : ""]}>
                  <img src={img} alt="" class:list={["w-full object-cover transition-transform duration-500 hover:scale-[1.03]", imgIdx === 0 && cp.images.length % 2 !== 0 ? "aspect-[16/9]" : "aspect-[4/3]"]} loading="lazy" />
                </div>
              ))}
            </div>
          )}

          <p class="text-base leading-[1.9] text-surface-700 sm:text-lg sm:leading-[1.9]">{cp.text}</p>

          {idx < totalCp - 1 && (
            <div class="mt-14 flex items-center justify-center gap-3 sm:mt-20">
              <span class="h-px w-12 bg-surface-200"></span>
              <span class="h-1.5 w-1.5 rounded-full bg-amber-300"></span>
              <span class="h-px w-12 bg-surface-200"></span>
            </div>
          )}
        </section>
      ))}

      <!-- Footer -->
      <footer class="mt-20 sm:mt-28">
        <div class="h-px bg-gradient-to-r from-transparent via-amber-200 to-transparent"></div>
        <div class="mt-10 flex flex-col items-center gap-5 text-center">
          <img src={thread.authorAvatar} alt={thread.author} class="h-14 w-14 rounded-full object-cover ring-2 ring-amber-100" />
          <div>
            <p class="text-sm font-semibold text-surface-800">{thread.author}</p>
            <p class="mt-1 text-xs text-surface-400">{fmt(thread.createdAt)} の旅の記録</p>
          </div>
          <button
            data-goto="checkpoint-post"
            class="inline-flex items-center gap-2 rounded-full bg-gradient-to-r from-amber-500 to-orange-500 px-6 py-2.5 text-sm font-semibold text-white shadow-lg shadow-amber-500/25 transition hover:shadow-xl active:scale-95"
          >
            <svg class="h-4 w-4" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2.5"><path stroke-linecap="round" stroke-linejoin="round" d="M12 4.5v15m7.5-7.5h-15" /></svg>
            チェックポイントを追加
          </button>
        </div>
      </footer>
    </article>
  </section>

  {/* ================================================================
      thread-public
      ================================================================ */}
  <section data-screen="thread-public" class="hidden">
    <article class="mx-auto max-w-[720px] px-5 py-10">
      <button data-back class="inline-flex items-center gap-1 text-sm font-medium text-surface-500 hover:text-amber-600 transition mb-8">
        <svg class="h-4 w-4" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2"><path stroke-linecap="round" stroke-linejoin="round" d="M15.75 19.5 8.25 12l7.5-7.5" /></svg>
        戻る
      </button>

      <div class="overflow-hidden rounded-2xl sm:rounded-3xl">
        <img src={publicThread.coverImage} alt={publicThread.title} class="aspect-[16/9] w-full object-cover" loading="lazy" />
      </div>

      <div class="mt-8 flex items-center gap-3">
        <span class="rounded-full bg-emerald-100 px-3 py-1 text-xs font-bold text-emerald-700">Public Event</span>
        <div class="flex -space-x-2">
          {pubAuthors.map(([name, avatar]) => (
            <img src={avatar} alt={name} class="h-8 w-8 rounded-full object-cover ring-2 ring-white" />
          ))}
        </div>
        <span class="text-xs text-surface-400">{pubAuthors.length} 人の参加者</span>
      </div>

      <h1 class="mt-5 font-serif text-4xl leading-tight tracking-tight text-surface-900 sm:text-5xl sm:leading-[1.15]">
        {publicThread.title}
      </h1>
      <p class="mt-4 text-lg leading-relaxed text-surface-500">{publicThread.description}</p>

      <div class="mt-6 flex items-center gap-3 text-xs text-surface-400">
        <span>{fmt(publicThread.createdAt)}</span>
        <span>·</span>
        <span>{publicThread.checkpoints.length} チェックポイント</span>
      </div>

      <!-- Action buttons -->
      <div class="mt-6 flex flex-wrap gap-2">
        <button data-goto="share" class="inline-flex items-center gap-1.5 rounded-full border border-surface-200 bg-white px-4 py-2 text-sm font-medium text-surface-600 shadow-sm transition hover:border-amber-300 hover:text-amber-700 hover:shadow active:scale-95">
          共有
        </button>
        <button data-goto="bsky-crosspost" class="inline-flex items-center gap-1.5 rounded-full border border-surface-200 bg-white px-4 py-2 text-sm font-medium text-surface-600 shadow-sm transition hover:border-amber-300 hover:text-amber-700 hover:shadow active:scale-95">
          Blueskyに投稿
        </button>
        <button data-goto="bsky-import" class="inline-flex items-center gap-1.5 rounded-full border border-surface-200 bg-white px-4 py-2 text-sm font-medium text-surface-600 shadow-sm transition hover:border-amber-300 hover:text-amber-700 hover:shadow active:scale-95">
          インポート
        </button>
      </div>

      <div class="mt-8 h-px bg-gradient-to-r from-transparent via-amber-200 to-transparent"></div>

      <!-- Checkpoints with author bylines -->
      {publicThread.checkpoints.map((cp, idx) => {
        const colors = ["border-amber-400", "border-sky-400", "border-violet-400"];
