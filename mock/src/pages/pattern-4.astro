<script>
  const screens = document.querySelectorAll<HTMLElement>('[data-screen]');
  const history: string[] = ['login'];

  function show(id: string, pushHistory = true) {
    screens.forEach(s => s.classList.add('hidden'));
    const target = document.querySelector(`[data-screen="${id}"]`);
    if (target) {
      target.classList.remove('hidden');
      target.classList.add('animate-fade-in');
      setTimeout(() => target.classList.remove('animate-fade-in'), 300);
      window.scrollTo(0, 0);
    }
    if (pushHistory && history[history.length - 1] !== id) history.push(id);
  }

  document.addEventListener('click', (e) => {
    const btn = (e.target as HTMLElement).closest('[data-goto]') as HTMLElement;
    if (btn) { show(btn.dataset.goto!); return; }
    const back = (e.target as HTMLElement).closest('[data-back]') as HTMLElement;
    if (back) { history.pop(); show(history[history.length - 1] || 'login', false); }
  });

  // Tab switching on home screen
  document.querySelectorAll('#home-tabs [data-tab]').forEach(tab => {
    tab.addEventListener('click', () => {
      const target = (tab as HTMLElement).dataset.tab;
      document.querySelectorAll('#home-tabs [data-tab]').forEach(t => {
        t.classList.remove('bg-white', 'shadow-sm', 'font-semibold', 'text-surface-800');
        t.classList.add('font-medium', 'text-surface-500');
      });
      tab.classList.add('bg-white', 'shadow-sm', 'font-semibold', 'text-surface-800');
      tab.classList.remove('font-medium', 'text-surface-500');

      document.getElementById('tab-threads')!.classList.toggle('hidden', target !== 'threads');
      document.getElementById('tab-bookmarks')!.classList.toggle('hidden', target !== 'bookmarks');
    });
  });

  show('login', false);
</script>

