---
import Layout from "../layouts/Layout.astro";
import { thread, publicThread, threadList, bookmarks, blueskyPosts } from "../data/mock.ts";

const selectedCount = blueskyPosts.filter((p) => p.selected).length;

const authorDotColor: Record<string, string> = {
  shino3: "bg-primary-500 text-white",
  yuki: "bg-amber-500 text-white",
  taro: "bg-violet-500 text-white",
};
const authorCardBorder: Record<string, string> = {
  shino3: "border-primary-200",
  yuki: "border-amber-200",
  taro: "border-violet-200",
};
---

<Layout title="Pattern 1: Timeline Feed">

  {/* ===== login ===== */}
  <section data-screen="login" class="hidden">
    <div class="flex min-h-[calc(100vh-3.5rem)] items-center justify-center px-4 py-12">
      <div class="w-full max-w-md rounded-2xl border border-surface-200 bg-white p-8 shadow-sm">
        <div class="mb-8 text-center">
          <div class="mx-auto mb-4 flex size-16 items-center justify-center rounded-2xl bg-primary-500 shadow-lg shadow-primary-500/20">
            <svg class="size-8 text-white" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2">
              <path stroke-linecap="round" stroke-linejoin="round" d="M9 20l-5.447-2.724A1 1 0 013 16.382V5.618a1 1 0 011.447-.894L9 7m0 13l6-3m-6 3V7m6 10l4.553 2.276A1 1 0 0021 18.382V7.618a1 1 0 00-.553-.894L15 4m0 13V4m0 0L9 7" />
            </svg>
          </div>
          <h1 class="text-2xl font-bold tracking-tight text-surface-900">Trailcast</h1>
          <p class="mt-1 text-sm text-surface-500">旅の足跡をスレッドに記録する</p>
        </div>

        <h2 class="mb-5 text-center text-base font-semibold text-surface-700">AT Protocol でログイン</h2>

        <div class="space-y-4">
          <div>
            <label class="mb-1.5 block text-sm font-medium text-surface-600">ハンドル</label>
            <input
              type="text"
              placeholder="handle.bsky.social"
              class="w-full rounded-xl border border-surface-200 bg-surface-50 px-4 py-3 text-sm text-surface-800 placeholder-surface-400 outline-none transition focus:border-primary-400 focus:ring-2 focus:ring-primary-100"
            />
          </div>
          <button data-goto="home" class="w-full rounded-xl bg-primary-500 px-4 py-3 text-sm font-semibold text-white shadow-sm transition hover:bg-primary-600 active:scale-[0.98]">
            ログイン
          </button>
        </div>

        <p class="mt-5 text-center text-xs text-surface-400">Bluesky アカウントで認証します</p>
      </div>
    </div>
  </section>

  {/* ===== home ===== */}
  <section data-screen="home" class="hidden">
    <div class="mx-auto max-w-2xl px-4 py-6">
      <div class="mb-5 flex items-center justify-between">
        <div class="flex gap-1 rounded-xl bg-surface-100 p-1">
          <button id="tab-threads" class="rounded-lg bg-white px-4 py-2 text-sm font-semibold text-primary-600 shadow-sm">スレッド</button>
          <button id="tab-bookmarks" class="rounded-lg px-4 py-2 text-sm font-medium text-surface-500 transition hover:text-surface-700">ブックマーク</button>
        </div>
        <button data-goto="thread-create" class="flex items-center gap-2 rounded-xl bg-primary-500 px-4 py-2.5 text-sm font-semibold text-white shadow-sm transition hover:bg-primary-600 active:scale-[0.98]">
          <svg class="size-4" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2.5">
            <path stroke-linecap="round" stroke-linejoin="round" d="M12 4v16m8-8H4" />
          </svg>
          新しいスレッド
        </button>
      </div>

      {/* Thread list sub-view */}
      <div id="view-threads" class="space-y-3">
        {threadList.map((t, idx) => (
          <div
            data-goto={idx === 0 ? "thread-private" : idx === 1 ? "thread-public" : undefined}
            class:list={[
              "flex gap-4 rounded-2xl border border-surface-200 bg-white p-4 shadow-sm transition hover:shadow-md",
              idx <= 1 && "cursor-pointer",
            ]}
          >
            <img
              src={t.coverImage}
              alt={t.title}
              class="size-20 shrink-0 rounded-xl object-cover"
              loading="lazy"
            />
            <div class="min-w-0 flex-1">
              <div class="flex items-start justify-between gap-2">
                <h3 class="truncate text-base font-semibold text-surface-800">{t.title}</h3>
                <span
                  class:list={[
                    "shrink-0 rounded-full px-2.5 py-0.5 text-[11px] font-semibold",
                    t.visibility === "public"
                      ? "bg-emerald-100 text-emerald-700"
                      : "bg-surface-100 text-surface-500",
                  ]}
                >
                  {t.visibility === "public" ? "Public" : "Private"}
                </span>
              </div>
              <p class="mt-1 line-clamp-2 text-sm leading-relaxed text-surface-500">{t.description}</p>
              <div class="mt-2 flex items-center gap-3 text-xs text-surface-400">
                <span>{t.createdAt}</span>
                <span class="flex items-center gap-1">
                  <svg class="size-3.5" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2">
                    <path stroke-linecap="round" stroke-linejoin="round" d="M17.657 16.657L13.414 20.9a1.998 1.998 0 01-2.827 0l-4.244-4.243a8 8 0 1111.314 0z" />
                    <path stroke-linecap="round" stroke-linejoin="round" d="M15 11a3 3 0 11-6 0 3 3 0 016 0z" />
                  </svg>
                  {t.checkpoints.length} チェックポイント
                </span>
              </div>
            </div>
          </div>
        ))}
      </div>

      {/* Bookmark sub-view */}
      <div id="view-bookmarks" class="hidden space-y-3">
        {bookmarks.map((bm) => (
          <div class="flex gap-4 rounded-2xl border border-surface-200 bg-white p-4 shadow-sm transition hover:shadow-md cursor-pointer" data-goto="thread-public">
            <img
              src={bm.thread.coverImage}
              alt={bm.thread.title}
              class="size-16 shrink-0 rounded-xl object-cover"
              loading="lazy"
            />
            <div class="min-w-0 flex-1">
              <h3 class="truncate text-sm font-semibold text-surface-800">{bm.thread.title}</h3>
              <p class="mt-0.5 text-xs text-surface-500">{bm.thread.description}</p>
              <div class="mt-1.5 flex items-center gap-2 text-xs text-surface-400">
                <img src={bm.thread.authorAvatar} alt={bm.thread.author} class="size-4 rounded-full" loading="lazy" />
                <span>{bm.thread.author}</span>
                <span>·</span>
                <span>保存日: {bm.createdAt}</span>
              </div>
            </div>
          </div>
        ))}
      </div>
    </div>
  </section>

  {/* ===== thread-create ===== */}
  <section data-screen="thread-create" class="hidden">
    <div class="mx-auto max-w-lg px-4 py-6">
      <button data-back class="mb-4 flex items-center gap-1 text-sm font-medium text-primary-600 transition hover:text-primary-700">
        <svg class="size-4" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2.5"><path stroke-linecap="round" stroke-linejoin="round" d="M15 19l-7-7 7-7" /></svg>
        スレッド一覧
      </button>

      <div class="rounded-2xl border border-surface-200 bg-white p-6 shadow-sm">
        <h2 class="mb-6 text-lg font-bold text-surface-800">新しいスレッドを作成</h2>

        <div class="space-y-5">
          <div>
            <label class="mb-1.5 block text-sm font-medium text-surface-600">タイトル</label>
            <input type="text" placeholder="スレッドのタイトル" class="w-full rounded-xl border border-surface-200 bg-surface-50 px-4 py-3 text-sm text-surface-800 placeholder-surface-400 outline-none transition focus:border-primary-400 focus:ring-2 focus:ring-primary-100" />
          </div>

          <div>
            <label class="mb-1.5 block text-sm font-medium text-surface-600">概要</label>
            <textarea placeholder="概要を入力（任意）" rows="3" class="w-full resize-none rounded-xl border border-surface-200 bg-surface-50 px-4 py-3 text-sm text-surface-800 placeholder-surface-400 outline-none transition focus:border-primary-400 focus:ring-2 focus:ring-primary-100"></textarea>
          </div>

          <div>
            <label class="mb-1.5 block text-sm font-medium text-surface-600">公開設定</label>
            <div class="flex gap-1 rounded-xl bg-surface-100 p-1">
              <button class="flex-1 rounded-lg px-4 py-2.5 text-sm font-medium text-surface-500 transition hover:text-surface-700">Private</button>
              <button class="flex-1 rounded-lg bg-emerald-500 px-4 py-2.5 text-sm font-semibold text-white shadow-sm">Public</button>
            </div>
            <p class="mt-1.5 text-xs text-surface-400">Public: 誰でもスレッドを閲覧でき、他のユーザーもチェックポイントを追加できます</p>
          </div>

          <div>
            <label class="mb-1.5 block text-sm font-medium text-surface-600">カバー画像</label>
            <div class="flex h-36 items-center justify-center rounded-xl border-2 border-dashed border-surface-300 bg-surface-50 transition hover:border-primary-300 hover:bg-primary-50/30">
              <div class="text-center">
                <svg class="mx-auto size-8 text-surface-300" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="1.5">
                  <path stroke-linecap="round" stroke-linejoin="round" d="M2.25 15.75l5.159-5.159a2.25 2.25 0 013.182 0l5.159 5.159m-1.5-1.5l1.409-1.41a2.25 2.25 0 013.182 0l2.909 2.91m-18 3.75h16.5a1.5 1.5 0 001.5-1.5V6a1.5 1.5 0 00-1.5-1.5H3.75A1.5 1.5 0 002.25 6v12a1.5 1.5 0 001.5 1.5zm10.5-11.25h.008v.008h-.008V8.25zm.375 0a.375.375 0 11-.75 0 .375.375 0 01.75 0z" />
                </svg>
                <p class="mt-2 text-sm text-surface-400">タップして画像を選択</p>
              </div>
            </div>
          </div>

          <button data-goto="home" class="w-full rounded-xl bg-primary-500 px-4 py-3 text-sm font-semibold text-white shadow-sm transition hover:bg-primary-600 active:scale-[0.98]">
            作成
          </button>
        </div>
      </div>
    </div>
  </section>

  {/* ===== thread-private ===== */}
  <section data-screen="thread-private" class="hidden">
    <div class="mx-auto max-w-2xl px-4 py-6">
      <button data-back class="mb-4 flex items-center gap-1 text-sm font-medium text-primary-600 transition hover:text-primary-700">
        <svg class="size-4" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2.5"><path stroke-linecap="round" stroke-linejoin="round" d="M15 19l-7-7 7-7" /></svg>
        スレッド一覧
      </button>

      <div class="rounded-2xl border border-surface-200 bg-white p-6 shadow-sm">
        <div class="flex items-start gap-4">
          <img src={thread.coverImage} alt={thread.title} class="size-20 shrink-0 rounded-xl object-cover sm:size-24" loading="lazy" />
          <div class="min-w-0 flex-1">
            <div class="flex items-start gap-2">
              <h1 class="text-xl font-bold tracking-tight text-surface-900">{thread.title}</h1>
              <span class="shrink-0 rounded-full bg-surface-100 px-2.5 py-0.5 text-[11px] font-semibold text-surface-500">Private</span>
            </div>
            <p class="mt-1.5 text-sm leading-relaxed text-surface-500">{thread.description}</p>
            <div class="mt-3 flex items-center gap-2">
              <img src={thread.authorAvatar} alt={thread.author} class="size-6 rounded-full ring-2 ring-surface-100" loading="lazy" />
              <span class="text-sm font-medium text-surface-700">{thread.author}</span>
              <span class="text-xs text-surface-400">· {thread.createdAt}</span>
            </div>
          </div>
        </div>

        <div class="mt-5 flex flex-wrap gap-2 border-t border-surface-100 pt-4">
          <button data-goto="share" class="flex items-center gap-1.5 rounded-xl border border-surface-200 bg-surface-50 px-3.5 py-2 text-sm font-medium text-surface-600 transition hover:bg-surface-100">
            <svg class="size-4" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2">
              <path stroke-linecap="round" stroke-linejoin="round" d="M8.684 13.342C8.886 12.938 9 12.482 9 12c0-.482-.114-.938-.316-1.342m0 2.684a3 3 0 110-2.684m0 2.684l6.632 3.316m-6.632-6l6.632-3.316m0 0a3 3 0 105.367-2.684 3 3 0 00-5.367 2.684zm0 9.316a3 3 0 105.368 2.684 3 3 0 00-5.368-2.684z" />
            </svg>
            共有
          </button>
          <button data-goto="bsky-crosspost" class="flex items-center gap-1.5 rounded-xl border border-surface-200 bg-surface-50 px-3.5 py-2 text-sm font-medium text-surface-600 transition hover:bg-surface-100">
            <svg class="size-4 text-[#0085ff]" viewBox="0 0 24 24" fill="currentColor">
              <path d="M12 2C6.477 2 2 6.477 2 12s4.477 10 10 10 10-4.477 10-10S17.523 2 12 2zm4.862 7.222l-1.46 6.878c-.11.488-.396.607-.804.378l-2.22-1.636-1.07 1.032c-.12.118-.22.218-.448.218l.16-2.254 4.1-3.704c.18-.158-.038-.246-.276-.088l-5.07 3.192-2.182-.682c-.474-.148-.484-.474.1-.702l8.53-3.29c.396-.142.74.096.612.702l.028-.044z" />
            </svg>
            Blueskyに投稿
          </button>
          <button data-goto="bsky-import" class="flex items-center gap-1.5 rounded-xl border border-surface-200 bg-surface-50 px-3.5 py-2 text-sm font-medium text-surface-600 transition hover:bg-surface-100">
            <svg class="size-4" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2">
              <path stroke-linecap="round" stroke-linejoin="round" d="M4 16v1a3 3 0 003 3h10a3 3 0 003-3v-1m-4-8l-4-4m0 0L8 8m4-4v12" />
            </svg>
            インポート
          </button>
          <button class="flex items-center gap-1.5 rounded-xl border border-surface-200 bg-surface-50 px-3.5 py-2 text-sm font-medium text-surface-600 transition hover:bg-surface-100">
            <svg class="size-4" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2">
              <path stroke-linecap="round" stroke-linejoin="round" d="M16.862 4.487l1.687-1.688a1.875 1.875 0 112.652 2.652L10.582 16.07a4.5 4.5 0 01-1.897 1.13L6 18l.8-2.685a4.5 4.5 0 011.13-1.897l8.932-8.931zm0 0L19.5 7.125M18 14v4.75A2.25 2.25 0 0115.75 21H5.25A2.25 2.25 0 013 18.75V8.25A2.25 2.25 0 015.25 6H10" />
            </svg>
            編集
          </button>
        </div>
      </div>

      {/* Timeline */}
      <div class="relative mt-6 pl-6 sm:pl-8">
        <div class="absolute top-0 bottom-0 left-[1.15rem] w-0.5 bg-gradient-to-b from-primary-300 via-primary-200 to-surface-200 sm:left-[1.65rem]" aria-hidden="true" />

        <ol class="relative space-y-6">
          {thread.checkpoints.map((cp, i) => (
            <li class="relative pl-8 sm:pl-10">
              <div
                class:list={[
                  "absolute left-[-0.35rem] top-1 flex size-7 items-center justify-center rounded-full ring-4 ring-white sm:left-[-0.1rem]",
                  i === 0 ? "bg-primary-500 text-white" : "bg-surface-200 text-surface-500",
                ]}
              >
                <span class="text-[10px] font-bold">{i + 1}</span>
              </div>

              <div class="group rounded-2xl border border-surface-200 bg-white shadow-sm">
                <div class="flex flex-wrap items-center gap-2 px-4 pt-4 pb-2">
                  <span class="rounded-full bg-primary-50 px-2.5 py-0.5 text-xs font-semibold text-primary-700">{cp.time}</span>
                  {cp.location && (
                    <span class="flex items-center gap-1 text-xs text-surface-500">
                      <svg class="size-3.5" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2">
                        <path stroke-linecap="round" stroke-linejoin="round" d="M17.657 16.657L13.414 20.9a1.998 1.998 0 01-2.827 0l-4.244-4.243a8 8 0 1111.314 0z" />
                        <path stroke-linecap="round" stroke-linejoin="round" d="M15 11a3 3 0 11-6 0 3 3 0 016 0z" />
                      </svg>
                      {cp.location}
                    </span>
                  )}
                  <button data-goto="checkpoint-edit" class="ml-auto flex size-7 items-center justify-center rounded-lg text-surface-300 opacity-0 transition hover:bg-surface-100 hover:text-surface-500 group-hover:opacity-100" aria-label="編集">
                    <svg class="size-3.5" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2">
                      <path stroke-linecap="round" stroke-linejoin="round" d="M16.862 4.487l1.687-1.688a1.875 1.875 0 112.652 2.652L10.582 16.07a4.5 4.5 0 01-1.897 1.13L6 18l.8-2.685a4.5 4.5 0 011.13-1.897l8.932-8.931zm0 0L19.5 7.125M18 14v4.75A2.25 2.25 0 0115.75 21H5.25A2.25 2.25 0 013 18.75V8.25A2.25 2.25 0 015.25 6H10" />
                    </svg>
                  </button>
                </div>

                {cp.images.length > 0 && (
                  <div
                    class:list={[
                      "grid gap-1 px-4",
                      cp.images.length === 1 && "grid-cols-1",
                      cp.images.length === 2 && "grid-cols-2",
                      cp.images.length === 3 && "grid-cols-3",
                      cp.images.length >= 4 && "grid-cols-2",
                    ]}
                  >
                    {cp.images.map((img, imgIdx) => (
                      <img
                        src={img}
                        alt={`${cp.location ?? "Checkpoint"} photo ${imgIdx + 1}`}
                        class:list={[
                          "w-full rounded-xl object-cover",
                          cp.images.length === 1 ? "aspect-[16/9]" : "aspect-square",
                        ]}
                        loading="lazy"
                      />
                    ))}
                  </div>
                )}

                <p class="px-4 pt-3 pb-4 text-sm leading-relaxed text-surface-700">{cp.text}</p>
              </div>
            </li>
          ))}
        </ol>

        <div class="relative mt-6 pl-8 sm:pl-10">
          <div class="absolute left-[-0.35rem] top-0.5 flex size-7 items-center justify-center rounded-full bg-surface-100 ring-4 ring-white sm:left-[-0.1rem]">
            <svg class="size-3.5 text-surface-400" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2">
              <path stroke-linecap="round" stroke-linejoin="round" d="M5 13l4 4L19 7" />
            </svg>
          </div>
          <p class="py-1 text-xs font-medium text-surface-400">旅の終わり · {thread.checkpoints.length} チェックポイント</p>
        </div>
      </div>

      <div class="mt-6 flex justify-center">
        <button data-goto="checkpoint-post" class="flex items-center gap-2 rounded-full bg-primary-500 px-6 py-3 text-sm font-semibold text-white shadow-lg shadow-primary-500/25 transition hover:bg-primary-600 active:scale-95">
          <svg class="size-5" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2.5">
            <path stroke-linecap="round" stroke-linejoin="round" d="M12 4v16m8-8H4" />
          </svg>
          チェックポイントを追加
        </button>
      </div>
    </div>
  </section>

  {/* ===== thread-public ===== */}
  <section data-screen="thread-public" class="hidden">
    <div class="mx-auto max-w-2xl px-4 py-6">
      <button data-back class="mb-4 flex items-center gap-1 text-sm font-medium text-primary-600 transition hover:text-primary-700">
        <svg class="size-4" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2.5"><path stroke-linecap="round" stroke-linejoin="round" d="M15 19l-7-7 7-7" /></svg>
        スレッド一覧
      </button>

      <div class="rounded-2xl border border-surface-200 bg-white p-6 shadow-sm">
        <div class="flex items-start gap-4">
          <img src={publicThread.coverImage} alt={publicThread.title} class="size-20 shrink-0 rounded-xl object-cover sm:size-24" loading="lazy" />
          <div class="min-w-0 flex-1">
            <div class="flex items-start gap-2">
              <h1 class="text-xl font-bold tracking-tight text-surface-900">{publicThread.title}</h1>
              <span class="shrink-0 rounded-full bg-emerald-100 px-2.5 py-0.5 text-[11px] font-semibold text-emerald-700">Public</span>
            </div>
            <p class="mt-1.5 text-sm leading-relaxed text-surface-500">{publicThread.description}</p>
            <div class="mt-3 flex items-center gap-3">
              <div class="flex items-center">
                <div class="flex -space-x-2">
                  <img src={publicThread.authorAvatar} alt="shino3" class="size-6 rounded-full ring-2 ring-white" loading="lazy" />
                  <img src={publicThread.checkpoints[1].authorAvatar} alt="yuki" class="size-6 rounded-full ring-2 ring-white" loading="lazy" />
                  <img src={publicThread.checkpoints[2].authorAvatar} alt="taro" class="size-6 rounded-full ring-2 ring-white" loading="lazy" />
                </div>
                <span class="ml-2 text-xs font-medium text-surface-500">3 participants</span>
              </div>
              <span class="text-xs text-surface-400">· {publicThread.createdAt}</span>
            </div>
          </div>
        </div>

        <div class="mt-5 flex flex-wrap gap-2 border-t border-surface-100 pt-4">
          <button data-goto="share" class="flex items-center gap-1.5 rounded-xl border border-surface-200 bg-surface-50 px-3.5 py-2 text-sm font-medium text-surface-600 transition hover:bg-surface-100">
            <svg class="size-4" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2">
              <path stroke-linecap="round" stroke-linejoin="round" d="M8.684 13.342C8.886 12.938 9 12.482 9 12c0-.482-.114-.938-.316-1.342m0 2.684a3 3 0 110-2.684m0 2.684l6.632 3.316m-6.632-6l6.632-3.316m0 0a3 3 0 105.367-2.684 3 3 0 00-5.367 2.684zm0 9.316a3 3 0 105.368 2.684 3 3 0 00-5.368-2.684z" />
            </svg>
            共有
          </button>
          <button data-goto="bsky-crosspost" class="flex items-center gap-1.5 rounded-xl border border-surface-200 bg-surface-50 px-3.5 py-2 text-sm font-medium text-surface-600 transition hover:bg-surface-100">
            <svg class="size-4 text-[#0085ff]" viewBox="0 0 24 24" fill="currentColor">
              <path d="M12 2C6.477 2 2 6.477 2 12s4.477 10 10 10 10-4.477 10-10S17.523 2 12 2zm4.862 7.222l-1.46 6.878c-.11.488-.396.607-.804.378l-2.22-1.636-1.07 1.032c-.12.118-.22.218-.448.218l.16-2.254 4.1-3.704c.18-.158-.038-.246-.276-.088l-5.07 3.192-2.182-.682c-.474-.148-.484-.474.1-.702l8.53-3.29c.396-.142.74.096.612.702l.028-.044z" />
            </svg>
            Blueskyに投稿
          </button>
